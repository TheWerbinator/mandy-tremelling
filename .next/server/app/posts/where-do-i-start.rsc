12:{"metadata":[["$","title","0",{"children":"Where should I start when writing my book I've planned?"}],["$","meta","1",{"name":"description","content":"I was asked where he should start with his book. I realized I don't remember where I started. I thought it was worth it to write what I told him."}],["$","meta","2",{"property":"og:title","content":"Where should I start when writing my book I've planned?"}],["$","meta","3",{"property":"og:description","content":"I was asked where he should start with his book. I realized I don't remember where I started. I thought it was worth it to write what I told him."}],["$","meta","4",{"property":"og:url","content":"https://mandytremelling.com"}],["$","meta","5",{"property":"og:site_name","content":"Mandy Tremelling | Young Adult & Fantasy Author"}],["$","meta","6",{"property":"og:image","content":"https://mandytremelling.com/"}],["$","meta","7",{"property":"og:type","content":"website"}],["$","meta","8",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","9",{"name":"twitter:creator","content":"@payloadcms"}],["$","meta","10",{"name":"twitter:title","content":"Where should I start when writing my book I've planned?"}],["$","meta","11",{"name":"twitter:description","content":"I was asked where he should start with his book. I realized I don't remember where I started. I thought it was worth it to write what I told him."}],["$","meta","12",{"name":"twitter:image","content":"https://mandytremelling.com/"}]],"error":null,"digest":"$undefined"}
