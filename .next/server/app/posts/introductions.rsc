//mandytremelling.com/api/media/file/8b2dd22d-9b86-45ee-8e27-d4fca428f57e-300x266.jpg","width":300,"height":266,"mimeType":"image/jpeg","filesize":15266,"filename":"8b2dd22d-9b86-45ee-8e27-d4fca428f57e-300x266.jpg"},"square":{"url":"https://mandytremelling.com/api/media/file/8b2dd22d-9b86-45ee-8e27-d4fca428f57e-500x500.jpg","width":500,"height":500,"mimeType":"image/jpeg","filesize":37265,"filename":"8b2dd22d-9b86-45ee-8e27-d4fca428f57e-500x500.jpg"},"small":{"url":"https://mandytremelling.com/api/media/file/8b2dd22d-9b86-45ee-8e27-d4fca428f57e-600x532.jpg","width":600,"height":532,"mimeType":"image/jpeg","filesize":41142,"filename":"8b2dd22d-9b86-45ee-8e27-d4fca428f57e-600x532.jpg"},"medium":{"url":"https://mandytremelling.com/api/media/file/8b2dd22d-9b86-45ee-8e27-d4fca428f57e-900x797.jpg","width":900,"height":797,"mimeType":"image/jpeg","filesize":69634,"filename":"8b2dd22d-9b86-45ee-8e27-d4fca428f57e-900x797.jpg"},"large":{"url":"https://mandytremelling.com/api/media/file/8b2dd22d-9b86-45ee-8e27-d4fca428f57e-1400x1240.jpg","width":1400,"height":1240,"mimeType":"image/jpeg","filesize":126678,"filename":"8b2dd22d-9b86-45ee-8e27-d4fca428f57e-1400x1240.jpg"},"xlarge":{"url":"https://mandytremelling.com/api/media/file/8b2dd22d-9b86-45ee-8e27-d4fca428f57e-1920x1701.jpg","width":1920,"height":1701,"mimeType":"image/jpeg","filesize":194244,"filename":"8b2dd22d-9b86-45ee-8e27-d4fca428f57e-1920x1701.jpg"}}}}]}],["$","div",null,{"className":"absolute pointer-events-none left-0 bottom-0 w-full h-1/2 bg-gradient-to-t from-black to-transparent"}]]}]]}],["$","div",null,{"className":"flex flex-col items-center gap-4 pt-8","children":["$","div",null,{"className":"container","children":[["$","div",null,{"className":"prose dark:prose-invert max-w-[48rem] mx-auto","children":[["$","p","0",{"className":"col-start-2","children":[["$","$1","0",{"children":"Hello! I don't normally like talking about myself, but for some reason it is so much easier to introduce myself to strangers. So, even though I may already know some of you, I'm going to pretend I don't for a moment."}]]}],["$","p","1",{"className":"col-start-2","children":[["$","$1","0",{"children":"Starting from the beginning. I have been writing ever since my mom showed me I could staple papers together to make a book. Fast forward and I'm in an after school writing club in middle school. From that class I'll publish my two novellas and begin writing full length novels. The first of which will be published in 2018, "}],["$","em","1",{"children":["$","$1","1",{"children":"My World of Glass"}]}],["$","$1","2",{"children":"."}]]}],["$","p","2",{"className":"col-start-2","children":[["$","$1","0",{"children":"Away from writing, I live in Utah with my dream man (quite literally - I found 14 year old Me's \"wish list\" and he tics off all the requirements) and our daughter and our tri-colored corgi and yellow lab. I have a degree in criminal justice which accompanies my newest degree in social work, and I work in my dream job in child welfare. Basically, I've made it in life."}]]}],["$","p","3",{"className":"col-start-2","children":[["$","$1","0",{"children":"However, I'm not even 30 yet so I have a lot to keep working toward. Part of that goal is to publish more of my stories. I'm not one of those authors who is terrified of having people read their work. I would MUCH rather have people read it and tell me it wasn't for them. I write for an audience. It's what motivates me. So in order to keep my fantasy escape, I have to keep writing and keep sharing."}]]}],["$","p","4",{"className":"col-start-2","children":[["$","$1","0",{"children":"If you've followed me for a while you'll know occasionally I drop random musings. But I try to keep my posts relevant. Please ask me questions and please let me know what kind of content you would like to see. I want to have conversations with my readers! Thank you for joining me on my journey, I am so glad you're here."}]]}]]}],false]}]}]]}]
