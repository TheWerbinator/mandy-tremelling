7:["$","article",null,{"className":"pb-24","children":[["$","$L17",null,{}],"$L18",["$","$L19",null,{"type":"highImpact","richText":{"root":{"children":[{"children":[{"detail":0,"format":0,"mode":"normal","style":"","text":"Coming Soon!","type":"text","version":1}],"direction":"ltr","format":"start","indent":0,"type":"heading","version":1,"tag":"h1"},{"children":[{"detail":0,"format":0,"mode":"normal","style":"","text":"Launching August 1, 2025: ","type":"text","version":1},{"detail":0,"format":2,"mode":"normal","style":"","text":"Pulchra Arcanum","type":"text","version":1},{"detail":0,"format":0,"mode":"normal","style":"","text":" (Book 1 of the Domum Chronicles) by Mandy Tremelling","type":"text","version":1}],"direction":"ltr","format":"start","indent":0,"type":"paragraph","version":1,"textFormat":0,"textStyle":""},{"children":[],"direction":null,"format":"start","indent":0,"type":"paragraph","version":1,"textFormat":0,"textStyle":""},{"children":[{"detail":0,"format":2,"mode":"normal","style":"","text":"Merlin is a liar.","type":"text","version":1}],"direction":"ltr","format":"start","indent":0,"type":"heading","version":1,"tag":"h4"},{"children":[{"detail":0,"format":2,"mode":"normal","style":"","text":"Arthur is vengeful.","type":"text","version":1}],"direction":"ltr","format":"start","indent":0,"type":"heading","version":1,"tag":"h4"},{"children":[{"detail":0,"format":2,"mode":"normal","style":"","text":"Megara is confused.","type":"text","version":1}],"direction":"ltr","format":"start","indent":0,"type":"heading","version":1,"tag":"h4"},{"children":[],"direction":null,"format":"start","indent":0,"type":"paragraph","version":1,"textFormat":0,"textStyle":""},{"children":[{"detail":0,"format":0,"mode":"normal","style":"","text":"Raised by the legendary ","type":"text","version":1},{"detail":0,"format":1,"mode":"normal","style":"","text":"Merlin","type":"text","version":1},{"detail":0,"format":0,"mode":"normal","style":"","text":", Megara always knew she was destined for great things. When the truth about her past is revealed and Merlin is killed, Megara is forced to flee and return to her roots.","type":"text","version":1}],"direction":"ltr","format":"start","indent":0,"type":"paragraph","version":1,"textFormat":0,"textStyle":""},{"children":[],"direction":null,"format":"start","indent":0,"type":"paragraph","version":1,"textFormat":0,"textStyle":""},{"children":[{"detail":0,"format":0,"mode":"normal","style":"","text":"With her unlikely animal sidekick Superus and newfound friends Leo and Adina, Megara learns more about who she is. When ","type":"text","version":1},{"detail":0,"format":1,"mode":"normal","style":"","text":"King Arthur","type":"text","version":1},{"detail":0,"format":0,"mode":"normal","style":"","text":" seeks revenge she must choose between embracing her fate or succumbing to the darkness within her.","type":"text","version":1}],"direction":"ltr","format":"start","indent":0,"type":"paragraph","version":1,"textFormat":0,"textStyle":""},{"children":[],"direction":null,"format":"start","indent":0,"type":"paragraph","version":1,"textFormat":0,"textStyle":""},{"children":[{"detail":0,"format":0,"mode":"normal","style":"","text":"With ","type":"text","version":1},{"detail":0,"format":1,"mode":"normal","style":"","text":"unreliable narration","type":"text","version":1},{"detail":0,"format":0,"mode":"normal","style":"","text":" and a ","type":"text","version":1},{"detail":0,"format":1,"mode":"normal","style":"","text":"slow burn romance","type":"text","version":1},{"detail":0,"format":0,"mode":"normal","style":"","text":", this ","type":"text","version":1},{"detail":0,"format":1,"mode":"normal","style":"","text":"Arthurian retelling ","type":"text","version":1},{"detail":0,"format":0,"mode":"normal","style":"","text":"will keep you on the edge of your seat until the very end.","type":"text","version":1}],"direction":"ltr","format":"start","indent":0,"type":"paragraph","version":1,"textFormat":0,"textStyle":""}],"d