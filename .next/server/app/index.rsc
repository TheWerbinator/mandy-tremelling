7:["$","article",null,{"className":"pb-24","children":[["$","$L1a",null,{}],"$L1b",["$","$L1c",null,{"type":"highImpact","richText":{"root":{"children":[{"children":[{"detail":0,"format":0,"mode":"normal","style":"","text":"Mandy Tremelling","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"heading","version":1,"tag":"h1"},{"children":[{"detail":0,"format":0,"mode":"normal","style":"","text":"Mandy resides in a rapidly growing city in Utah with her loving husband, daughter, and two dogs. She holds a degree in social work which is complimented by a degree in criminal justice, and has dedicated her career to child welfare--a field she is deeply passionate about.","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":0,"textStyle":""},{"children":[{"detail":0,"format":0,"mode":"normal","style":"","text":"In her literary pursuits Mandy has made a mark with her debut novel, ","type":"text","version":1},{"detail":0,"format":2,"mode":"normal","style":"","text":"My World of Glass","type":"text","version":1},{"detail":0,"format":0,"mode":"normal","style":"","text":", published in 2018, with an audiobook version released in 2023. Additionally she has authored two novellas during her high school years, both of which garnered local recognition and acclaim.","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":0,"textStyle":""}],"direction":"ltr","format":"","indent":0,"type":"root","version":1}},"links":[{"id":"67913c40d94eaa4a0d933d52","link":{"type":"reference","newTab":null,"reference":{"relationTo":"pages","value":{"id":2,"title":"Contact","slug":"contact"}},"url":"/posts","label":"Contact","appearance":"default"}}],"media":{"id":4,"alt":"Open book with flared pages, unreadable by viewer, against a light background","caption":{"root":{"children":[{"children":[{"detail":0,"format":0,"mode":"normal","style":"","text":"Photo by Marku